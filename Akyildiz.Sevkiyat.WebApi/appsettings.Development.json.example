{
  "ConnectionStrings": {
    "SevkiyatConnection": "Server=(localdb)\\mssqllocaldb;Database=AkyildizSevkiyat;Trusted_Connection=True;MultipleActiveResultSets=true"
  },
  "Jwt": {
    "Key": "YOUR_JWT_SECRET_KEY_MUST_BE_AT_LEAST_32_CHARS",
    "Issuer": "AkyildizSevkiyatInfo",
    "Audience": "AkyildizSevkiyatApp"
  },
  "ISSIp": {
    "BaseUrl": "http://YOUR_ISS_HOST:88/",
    "EndpointPath": "api/MethodExecuter/ExecuteMethod",
    "KullaniciAdi": "YOUR_ISS_USERNAME",
    "Sifre": "YOUR_ISS_PASSWORD",
    "BasicAuthUsername": "YOUR_BASIC_AUTH_USERNAME",
    "BasicAuthPassword": "YOUR_BASIC_AUTH_PASSWORD",
    "TimeoutSeconds": 60
  },
  "GoogleMaps": {
    "ApiKey": "YOUR_GOOGLE_MAPS_API_KEY"
  },
  "Netsis": {
    "BaseUrl": "http://YOUR_NETSIS_HOST:PORT",
    "KullaniciAdi": "YOUR_NETSIS_USERNAME",
    "Sifre": "YOUR_NETSIS_PASSWORD",
    "FirmaKodu": "0",
    "DbName": "YOUR_DB_NAME",
    "DbUser": "YOUR_DB_USER",
    "DbPassword": "YOUR_DB_PASSWORD",
    "DbType": "MsSql",
    "SubeKodu": "0",
    "IsletmeKodu": null,
    "DepoKodu": "1",
    "LoginPath": "api/v2/token",
    "SiparisPath": "api/v2/ItemSlips",
    "SatinalmaSiparisPath": "api/v2/ItemSlips",
    "IrsaliyePath": "api/v2/ItemSlips",
    "StokBakiyePath": "api/v2/Queries",
    "TimeoutSeconds": 30,
    "TokenExpiryMinutes": 55
  },
  "SeedData": {
    "AdminPassword": "YOUR_ADMIN_PASSWORD_MIN_8_CHARS"
  },
  "Smtp": {
    "Host": "localhost",
    "Port": 1025,
    "EnableSsl": false,
    "UserName": "dev",
    "Password": "dev",
    "FromAddress": "sevkiyat@yourdomain.local",
    "FromDisplayName": "Akyıldız Sevkiyat (DEV)"
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5173",
      "http://localhost:3000"
    ]
  },
  "IssImport": {
    "IntervalMinutes": 15,
    "LookbackDays": 1
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
