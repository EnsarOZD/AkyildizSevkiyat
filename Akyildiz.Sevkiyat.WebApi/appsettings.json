{
  "Cors": {
    "AllowedOrigins": [
      "https://sevkiyat.akyildizlojistik.com"
    ]
  },
  "PhotoStorage": {
    "BasePath": "/var/sevkiyat/photos"
  },
  "ConnectionStrings": {
    "SevkiyatConnection": "SET_BY_ENV_ConnectionStrings__SevkiyatConnection"
  },
  "Jwt": {
    "Key": "SET_BY_ENV_Jwt__Key",
    "Issuer": "AkyildizSevkiyatInfo",
    "Audience": "AkyildizSevkiyatApp",
    "ExpiresInMinutes": "60",
    "RefreshTokenExpiryHours": 8,
    "RememberMeExpiryHours": 168
  },
  "ISSIp": {
    "BaseUrl": "https://generalapi.issturkiye.com/",
    "EndpointPath": "api/MethodExecuter/ExecuteMethod",
    "KullaniciAdi": "SET_BY_ENV_ISSIp__KullaniciAdi",
    "Sifre": "SET_BY_ENV_ISSIp__Sifre",
    "BasicAuthUsername": "SET_BY_ENV_ISSIp__BasicAuthUsername",
    "BasicAuthPassword": "SET_BY_ENV_ISSIp__BasicAuthPassword",
    "TimeoutSeconds": 60
  },
  "Shipment": {
    "RequireIrsaliyeNoOnDispatch": false
  },
  "GoogleMaps": {
    "ApiKey": "SET_BY_ENV_GOOGLE_MAPS_API_KEY"
  },
  "Netsis": {
    "BaseUrl": "http://192.168.1.200:7071",
    "KullaniciAdi": "SET_BY_ENV_Netsis__KullaniciAdi",
    "Sifre": "SET_BY_ENV_Netsis__Sifre",
    "FirmaKodu": "SET_BY_ENV_Netsis__FirmaKodu",
    "DbName": "SET_BY_ENV_Netsis__DbName",
    "DbUser": "SET_BY_ENV_Netsis__DbUser",
    "DbPassword": "SET_BY_ENV_Netsis__DbPassword",
    "DbType": "MsSql",
    "SubeKodu": "0",
    "IsletmeKodu": null,
    "DepoKodu": "1",
    "LoginPath": "api/v2/token",
    "SiparisPath": "api/v2/ItemSlips",
    "SatinalmaSiparisPath": "api/v2/ItemSlips",
    "IrsaliyePath": "api/v2/ItemSlips",
    "StokBakiyePath": "api/v2/Queries",
    "TimeoutSeconds": 90,
    "TokenExpiryMinutes": 55
  },
  "SeedData": {
    "AdminPassword": "SET_BY_ENV_SeedData__AdminPassword"
  },
  "Smtp": {
    "Host": "SET_BY_ENV_Smtp__Host",
    "Port": 587,
    "EnableSsl": true,
    "UserName": "SET_BY_ENV_Smtp__UserName",
    "Password": "SET_BY_ENV_Smtp__Password",
    "FromAddress": "SET_BY_ENV_Smtp__FromAddress",
    "FromDisplayName": "Akyıldız Sevkiyat",
    "ProcurementFromAddress": "SET_BY_ENV_Smtp__ProcurementFromAddress",
    "ProcurementFromDisplayName": "Akyıldız Lojistik Satınalma",
    "ProcurementUserName": "SET_BY_ENV_Smtp__ProcurementUserName",
    "ProcurementPassword": "SET_BY_ENV_Smtp__ProcurementPassword",
    "SkipCertificateValidation": false,
    "DispatchTestRecipient": ""
  },
  "YurtiKargo": {
    "BaseUrl": "SET_BY_ENV_YurtiKargo__BaseUrl",
    "WsUserName": "SET_BY_ENV_YurtiKargo__WsUserName",
    "WsPassword": "SET_BY_ENV_YurtiKargo__WsPassword",
    "PaymentType": 1,
    "CargoKeyPrefix": "AKY-",
    "TimeoutSeconds": 30,
    "IntervalMinutes": 30
  },
  "Vapid": {
    "PublicKey": "SET_BY_ENV_Vapid__PublicKey",
    "PrivateKey": "SET_BY_ENV_Vapid__PrivateKey",
    "Subject": "mailto:ensarozd@gmail.com"
  },
  "IssImport": {
    "IntervalMinutes": "SET_BY_ENV_IssImport__IntervalMinutes",
    "LookbackDays": "SET_BY_ENV_IssImport__LookbackDays"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}