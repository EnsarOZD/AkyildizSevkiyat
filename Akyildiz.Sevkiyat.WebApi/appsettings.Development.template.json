{
  "PhotoStorage": {
    "BasePath": "photos"
  },
  "ConnectionStrings": {
    "SevkiyatConnection": "Server=(localdb)\\mssqllocaldb;Database=AkyildizSevkiyat;Trusted_Connection=True;MultipleActiveResultSets=true"
  },
  "Jwt": {
    "Key": "SET_BY_ENV_Jwt__Key",
    "Issuer": "AkyildizSevkiyatInfo",
    "Audience": "AkyildizSevkiyatApp"
  },
  "ISSIp": {
    "BaseUrl": "https://generalapi.issturkiye.com/",
    "EndpointPath": "api/MethodExecuter/ExecuteMethod",
    "KullaniciAdi": "SET_BY_ENV_ISSIp__KullaniciAdi",
    "Sifre": "SET_BY_ENV_ISSIp__Sifre",
    "BasicAuthUsername": "SET_BY_ENV_ISSIp__BasicAuthUsername",
    "BasicAuthPassword": "SET_BY_ENV_ISSIp__BasicAuthPassword",
    "TimeoutSeconds": 60
  },
  "GoogleMaps": {
    "ApiKey": "SET_BY_ENV_GOOGLE_MAPS_API_KEY"
  },
  "Netsis": {
    "BaseUrl": "http://192.168.1.200:7071",
    "KullaniciAdi": "SET_BY_ENV_Netsis__KullaniciAdi",
    "Sifre": "SET_BY_ENV_Netsis__Sifre",
    "FirmaKodu": "0",
    "DbName": "AKYILDIZ",
    "DbUser": "SET_BY_ENV_Netsis__DbUser",
    "DbPassword": "SET_BY_ENV_Netsis__DbPassword",
    "DbType": "MsSql",
    "SubeKodu": "0",
    "IsletmeKodu": null,
    "DepoKodu": "1",
    "LoginPath": "api/v2/token",
    "SiparisPath": "api/v2/ItemSlips",
    "SatinalmaSiparisPath": "api/v2/ItemSlips",
    "IrsaliyePath": "api/v2/ItemSlips",
    "StokBakiyePath": "api/v2/Queries",
    "TimeoutSeconds": 30,
    "TokenExpiryMinutes": 55
  },
  "SeedData": {
    "AdminPassword": "SET_BY_ENV_SeedData__AdminPassword"
  },
  "Smtp": {
    "Host": "localhost",
    "Port": 1025,
    "EnableSsl": false,
    "UserName": "SET_BY_ENV_Smtp__UserName",
    "Password": "SET_BY_ENV_Smtp__Password",
    "FromAddress": "sevkiyat@akyildiz.local",
    "FromDisplayName": "Akyıldız Sevkiyat (DEV)"
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5173",
      "http://localhost:3000"
    ]
  },
  "YurtiKargo": {
    "BaseUrl": "https://testws.yurticikargo.com/KOPSWebServices/ShippingOrderDispatcherServices",
    "WsUserName": "SET_BY_ENV_YurtiKargo__WsUserName",
    "WsPassword": "SET_BY_ENV_YurtiKargo__WsPassword",
    "PaymentType": 1,
    "CargoKeyPrefix": "AKY-",
    "TimeoutSeconds": 30,
    "ProxyUrl": "socks5://127.0.0.1:8888",
    "IntervalMinutes": 30
  },
  "Vapid": {
    "PublicKey": "SET_BY_ENV_Vapid__PublicKey",
    "PrivateKey": "SET_BY_ENV_Vapid__PrivateKey",
    "Subject": "mailto:set-your-contact@example.com"
  },
  "IssImport": {
    "IntervalMinutes": 15,
    "LookbackDays": 1
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
